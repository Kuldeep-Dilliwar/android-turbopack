+        unsafe{
+            IN_ALLOCATOR = true;
+        }
+
         let size = unsafe { base_alloc_size(ptr, layout) };
         unsafe { base_alloc().dealloc(ptr, layout) };
         remove(size);
+
+        #[cfg(target_os = "android")]
+        unsafe {
+            IN_ALLOCATOR = false;
+        }
     }
 
     unsafe fn alloc_zeroed(&self, layout: Layout) -> *mut u8 {
