             let size = unsafe { base_alloc_size(ret, layout) };
             add(size);
         }
+
+        #[cfg(target_os = "android")]
+        unsafe {
+            IN_ALLOCATOR = false;
+        }
+
         ret
     }
 
     unsafe fn realloc(&self, ptr: *mut u8, layout: Layout, new_size: usize) -> *mut u8 {
+
