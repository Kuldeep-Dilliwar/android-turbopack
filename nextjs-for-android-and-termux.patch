+
+#[cfg(target_os = "android")]
+#[thread_local]
+pub(crate) static IS_THREAD_EXITING_FLAG: UnsafeCell<bool> = UnsafeCell::new(false);
+
+#[cfg(target_os = "android")]
+#[inline(always)]
+fn should_bypass() -> bool {
+    unsafe { IN_ALLOCATOR || *IS_THREAD_EXITING_FLAG.get() }
+}
+
+#[cfg(not(target_os = "android"))]
+#[inline(always)]
+fn should_bypass() -> bool {
+    false
+}
+
