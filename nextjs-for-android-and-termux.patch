             let size = unsafe { base_alloc_size(ret, layout) };
             add(size);
         }
+
+        #[cfg(target_os = "android")]
+        unsafe {
+            IN_ALLOCATOR = false;
+        }
+
         ret
     }
 
     unsafe fn dealloc(&self, ptr: *mut u8, layout: Layout) {
