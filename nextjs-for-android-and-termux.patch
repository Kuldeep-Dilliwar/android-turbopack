From 771b2ccb9b53a5885efa04994de5793865a04bd3 Mon Sep 17 00:00:00 2001
From: Kuldeep Dilliwar <kuldeepdilliwar@gmail.com>
Date: Mon, 2 Feb 2026 17:33:34 +0530
Subject: [PATCH 19/23] Update counter.rs

CounterGuard::drop on Android doesn't call unload(), causing permanent over-counting of memory in the global ALLOCATED counter when threads exit so  we ensure that exactly when the thread is about to die (and the CounterGuard is dropped), it first "unloads" its memory credits back to the global counter, preventing the memory leak we discussed.
---
 turbopack/crates/turbo-tasks-malloc/src/counter.rs | 1 +
 1 file changed, 1 insertion(+)

diff --git a/turbopack/crates/turbo-tasks-malloc/src/counter.rs b/turbopack/crates/turbo-tasks-malloc/src/counter.rs
index 7f31b318313c4d..061426541bd4f2 100644
--- a/turbopack/crates/turbo-tasks-malloc/src/counter.rs
+++ b/turbopack/crates/turbo-tasks-malloc/src/counter.rs
@@ -137,6 +137,7 @@ struct CounterGuard(ThreadLocalCounter);
 #[cfg(target_os = "android")]
 impl Drop for CounterGuard {
     fn drop(&mut self) {
+        self.0.unload();
         unsafe {
             *IS_THREAD_EXITING_FLAG.get() = true;
         }

